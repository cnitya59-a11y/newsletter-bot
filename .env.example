# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Required for newsletter workflow
PERPLEXITY_API_KEY=        # perplexity.ai — research (sonar model)
ANTHROPIC_API_KEY=         # console.anthropic.com — newsletter copy (claude-opus-4-7)
OPENAI_API_KEY=            # platform.openai.com — AI images (DALL-E 3, ~$0.40/run)

# Gmail SMTP (for send_email.py)
GMAIL_ADDRESS=                    # your Gmail address
GMAIL_APP_PASSWORD=               # 16-char App Password from myaccount.google.com → Security → App passwords

# Google Sheets subscriber list
GOOGLE_SERVICE_ACCOUNT_JSON=credentials.json   # path to service account key file
SUBSCRIBERS_SHEET_ID=             # the long ID from your Google Sheet URL
SUBSCRIBERS_SHEET_NAME=Sheet1     # tab name (default: Sheet1)

# Future workflows
# AIRTABLE_API_KEY=
